    "cors": "^2.8.5",
    "express": "^4.18.2",
    "level": "^8.0.0",
    "socket.io": "^4.7.4",
    "concurrently": "^8.2.2",
    "@supabase/supabase-js": "^2.39.0",
    "firebase-admin": "^12.0.0",
    "ioredis": "^5.3.2"
  }
}
